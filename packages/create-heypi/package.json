{
	"name": "create-heypi",
	"version": "0.1.4",
	"description": "Create a heypi app.",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"create-heypi": "bin/create-heypi"
	},
	"files": [
		"bin/create-heypi",
		"dist",
		"README.md",
		"LICENSE"
	],
	"sideEffects": false,
	"engines": {
		"node": ">=22"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hunvreus/heypi.git",
		"directory": "packages/create-heypi"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.build.json",
		"check": "biome check . && tsc --noEmit",
		"test": "pnpm run build && node --import tsx --test tests/*.test.ts",
		"pack:dry": "npm pack --dry-run",
		"publish:dry": "npm publish --dry-run --access public",
		"prepack": "pnpm run build"
	},
	"dependencies": {
		"@clack/prompts": "^1.2.0",
		"picocolors": "^1.1.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/node": "^25.9.1",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3"
	},
	"packageManager": "pnpm@10.17.1"
}
