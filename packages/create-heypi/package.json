{
	"name": "create-heypi",
	"version": "0.1.0",
	"description": "Create a Heypi project from a bundled template.",
	"license": "MIT",
	"type": "module",
	"bin": {
		"create-heypi": "./dist/cli.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"engines": {
		"node": ">=22"
	},
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/hunvreus/heypi.git",
		"directory": "packages/create-heypi"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"pack:dry": "corepack pnpm run build && npm pack --dry-run",
		"publish:dry": "corepack pnpm run build && npm publish --dry-run --access public",
		"prepack": "corepack pnpm run build"
	},
	"dependencies": {
		"@hunvreus/heypi": "^0.1.0"
	},
	"devDependencies": {
		"@types/node": "^25.9.1",
		"typescript": "^6.0.3"
	},
	"packageManager": "pnpm@10.17.1"
}
