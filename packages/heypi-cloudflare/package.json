{
	"name": "@hunvreus/heypi-cloudflare",
	"version": "0.1.0",
	"description": "Cloudflare Worker + Durable Object host for heypi.",
	"private": true,
	"type": "module",
	"scripts": {
		"check": "biome check . && tsc --noEmit",
