{
	"name": "@hunvreus/heypi",
	"version": "0.1.0",
	"description": "Pi-native chat adapter shell for team agents.",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./authoring": {
			"types": "./dist/authoring.d.ts",
			"import": "./dist/authoring.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"sideEffects": false,
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.build.json",
		"check": "biome check .",
		"fmt": "biome format --write .",
		"typecheck": "corepack pnpm run build && tsc --noEmit",
		"test": "vitest --run",
		"pack:dry": "npm pack --dry-run",
		"publish:dry": "npm publish --dry-run --access public"
	},
	"dependencies": {
		"@earendil-works/pi-coding-agent": "^0.79.6",
		"@sinclair/typebox": "^0.34.49",
		"@slack/bolt": "^4.7.2",
		"discord.js": "^14.26.4"
	},
	"devDependencies": {
		"vitest": "^4.1.9"
	}
}
