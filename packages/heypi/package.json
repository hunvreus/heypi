{
	"name": "@hunvreus/heypi",
	"version": "0.1.0",
	"description": "Pi-native chat adapter shell for team agents.",
	"license": "MIT",
	"homepage": "https://github.com/hunvreus/heypi#readme",
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/hunvreus/heypi.git",
		"directory": "packages/heypi"
	},
	"bugs": {
		"url": "https://github.com/hunvreus/heypi/issues"
	},
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"heypi": "./dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./authoring": {
			"types": "./dist/authoring.d.ts",
			"import": "./dist/authoring.js"
		},
		"./cli": {
			"types": "./dist/cli.d.ts",
			"import": "./dist/cli.js"
		},
		"./runtime": {
			"types": "./dist/runtime.d.ts",
			"import": "./dist/runtime.js"
		}
	},
	"files": [
		"dist",
		"docs",
		"README.md",
		"LICENSE"
	],
	"sideEffects": false,
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.build.json && node scripts/copy-examples.mjs",
		"check": "biome check .",
		"fmt": "biome format --write .",
		"typecheck": "corepack pnpm run build && tsc --noEmit",
		"test": "vitest --run",
		"pack:dry": "corepack pnpm run build && npm pack --dry-run",
		"publish:dry": "corepack pnpm run build && npm publish --dry-run --access public"
	},
	"dependencies": {
		"@earendil-works/pi-coding-agent": "^0.79.6",
		"@sinclair/typebox": "^0.34.49",
		"@slack/bolt": "^4.7.2",
		"@slack/types": "^2.21.1",
		"croner": "^10.0.1",
		"discord.js": "^14.26.4",
		"jiti": "^2.7.0"
	},
	"devDependencies": {
		"vitest": "^4.1.9"
	}
}
