{
	"name": "@hunvreus/heypi-runtime-gondolin",
	"version": "0.3.0-beta.1",
	"description": "Gondolin micro-VM runtime provider for HeyPi.",
	"license": "MIT",
	"homepage": "https://heypi.dev/docs/configuration/runtimes/",
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/hunvreus/heypi.git",
		"directory": "packages/heypi-runtime-gondolin"
	},
	"bugs": {
		"url": "https://github.com/hunvreus/heypi/issues"
	},
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"engines": {
		"node": ">=23.6"
	},
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test": "vitest --run",
		"pack:dry": "npm pack --dry-run",
		"publish:dry": "npm publish --dry-run --access public",
		"publish:release": "npm publish --access public",
		"prepack": "npm run build"
	},
	"dependencies": {
		"@earendil-works/gondolin": "^0.12.0",
		"@hunvreus/heypi": "^0.3.0-beta.1"
	},
	"devDependencies": {
		"@types/node": "^25.9.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	},
	"publishConfig": {
		"access": "public"
	}
}
