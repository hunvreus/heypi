{
	"name": "heypi-workspace",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "pnpm --filter @hunvreus/heypi run build",
		"build:all": "pnpm --filter @hunvreus/heypi run build",
		"prepack": "pnpm run build",
		"pack:dry": "pnpm --filter @hunvreus/heypi run pack:dry",
		"pack:dry:packages": "pnpm -r --workspace-concurrency=1 --filter \"./packages/*\" run pack:dry",
		"publish:dry": "pnpm --filter @hunvreus/heypi run publish:dry",
		"publish:dry:packages": "pnpm -r --workspace-concurrency=1 --filter \"./packages/*\" run publish:dry",
		"check": "biome check .",
		"fmt": "biome format --write .",
		"typecheck": "pnpm --filter @hunvreus/heypi run typecheck",
		"test": "pnpm --filter @hunvreus/heypi run test"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@hunvreus/heypi": "workspace:*",
		"@types/node": "^25.9.1",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3"
	},
	"packageManager": "pnpm@10.17.1"
}
