{
	"name": "heypi-workspace",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/heypi",
		"packages/heypi-runtime-cloudflare",
		"packages/heypi-runtime-gondolin",
		"packages/heypi-runtime-just-bash",
		"packages/heypi-runtime-vercel",
		"packages/create-heypi"
	],
	"scripts": {
		"build": "corepack pnpm -r --filter \"./packages/*\" run build",
		"build:all": "corepack pnpm -r --filter \"./packages/*\" run build",
		"dev:codex-tag": "corepack pnpm --filter @hunvreus/heypi run build && corepack pnpm --filter heypi-example-codex-tag run dev",
		"prepack": "corepack pnpm run build",
		"pack:dry": "npm pack --workspaces --dry-run",
		"publish:dry": "npm publish --workspaces --dry-run --access public --tag latest",
		"publish:packages": "npm publish --workspaces --access public --tag latest",
		"check": "biome check .",
		"fmt": "biome format --write .",
		"typecheck": "corepack pnpm -r --filter \"./packages/*\" run typecheck",
		"test": "corepack pnpm --filter @hunvreus/heypi run build && corepack pnpm -r --filter \"./packages/*\" run test"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@hunvreus/heypi": "workspace:*",
		"@types/node": "^25.9.1",
		"typescript": "^6.0.3"
	},
	"packageManager": "pnpm@10.17.1"
}
