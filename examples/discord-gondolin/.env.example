DISCORD_BOT_TOKEN=<discord-bot-token>
DISCORD_CLIENT_ID=
OPENAI_API_KEY=<openai-api-key>

# Optional. Defaults to 0, which asks the OS for any free local port.
HEYPI_HTTP_PORT=0
# Optional. Set with HEYPI_HTTP_PORT to self-host secret requests locally.
# HEYPI_SECRET_URL=http://127.0.0.1:3000/secret

# Optional comma-separated allowlists. Empty means every delivered Discord event may trigger the bot.
HEYPI_DISCORD_CHANNELS=
HEYPI_DISCORD_USERS=
HEYPI_DISCORD_GROUPS=

# Optional comma-separated Discord user and role IDs for approvals and admin commands.
# Admins inherit approver permissions.
HEYPI_DISCORD_APPROVERS=
HEYPI_DISCORD_APPROVER_GROUPS=
HEYPI_DISCORD_ADMINS=
HEYPI_DISCORD_ADMIN_GROUPS=
