# Slack is optional. The example starts a local adapter without it.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Optional. Pi also supports /login and other provider env vars.
HEYPI_MODEL=openai/gpt-5.4-mini
OPENAI_API_KEY=

# Optional for the PR demo when using GitHub CLI.
# Runtime env is visible to model-driven commands; use only for trusted local demos.
GITHUB_TOKEN=

# Optional local paths/ports.
HEYPI_RUNTIME=docker
HEYPI_DOCKER_IMAGE=heypi-codex-tag:local
HEYPI_WORKSPACE=
HEYPI_STATE=
HEYPI_ADMIN_PORT=4321
HEYPI_ADMIN_TOKEN=
