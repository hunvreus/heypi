{
	"name": "heypi-example-codex-tag",
	"private": true,
	"type": "module",
	"scripts": {
		"docker:build": "docker build -t heypi-codex-tag:local .",
		"predev": "docker image inspect heypi-codex-tag:local >/dev/null 2>&1 || npm run docker:build",
		"dev": "node --env-file-if-exists=.env --import tsx index.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@hunvreus/heypi": "^0.1.0"
	},
	"devDependencies": {
		"@types/node": "^25.9.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	}
}
