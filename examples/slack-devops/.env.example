SLACK_BOT_TOKEN=<slack-bot-token>
SLACK_APP_TOKEN=<slack-app-token>
# SLACK_SIGNING_SECRET=... # HTTP mode only
OPENAI_API_KEY=<openai-api-key>

# Optional. Defaults to 0, which asks the OS for any free local port.
HEYPI_HTTP_PORT=0
# Optional. Set with HEYPI_HTTP_PORT to self-host secret requests locally.
# HEYPI_SECRET_URL=http://127.0.0.1:3000/secret

# Optional comma-separated allowlists. Empty means every delivered Slack event may trigger the bot.
HEYPI_SLACK_CHANNELS=
HEYPI_SLACK_USERS=
HEYPI_SLACK_GROUPS=

# Optional comma-separated Slack user and user group IDs for approvals and admin commands.
# Admins inherit approver permissions.
HEYPI_SLACK_APPROVERS=
HEYPI_SLACK_APPROVER_GROUPS=
HEYPI_SLACK_ADMINS=
HEYPI_SLACK_ADMIN_GROUPS=

# Optional target channel for scheduled demo jobs.
HEYPI_SLACK_JOB_CHANNEL=
