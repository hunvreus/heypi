# Copy to .dev.vars (gitignored). wrangler dev auto-loads it for the Worker, and the runner reads
# the same file via RUNNER_ENV.

# --- Worker (Cloudflare) needs these ---
TELEGRAM_BOT_TOKEN=
# Optional: set the same value when registering the webhook (setWebhook secret_token) to reject
# forged requests. Leave blank to skip verification.
TELEGRAM_WEBHOOK_SECRET=
# Where the Worker's Durable Object reaches the Pi runner service.
RUNNER_URL=http://127.0.0.1:8788

# --- Pi runner service (Node) needs these ---
HEYPI_MODEL=anthropic/claude-sonnet-4-6
ANTHROPIC_API_KEY=
# Or use OpenAI instead:
# HEYPI_MODEL=openai/gpt-5-mini
# OPENAI_API_KEY=
